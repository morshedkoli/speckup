# ─── Firebase Client SDK ──────────────────────────────────────────────────────
# These are NEXT_PUBLIC_* variables — safe to commit, required at build time.
# Firebase client config is intentionally public (security is via Firestore Rules).
#
# The Firebase Admin SDK (server-side) does NOT need env vars on Firebase Hosting:
# Cloud Run automatically injects Application Default Credentials.
# See src/lib/firebase-admin.ts for details.

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCLsloYVCZh2Od9E7YGfg2UaVEklV502OE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=speakup-ai-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=speakup-ai-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=speakup-ai-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=955029235432
NEXT_PUBLIC_FIREBASE_APP_ID=1:955029235432:web:bc6059e484c81adbb54b5d
